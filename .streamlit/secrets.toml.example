# Copy this file to secrets.toml and fill in real values for local dev.
# For Streamlit Community Cloud, paste these same keys into the app's
# "Secrets" panel in the dashboard (it's just TOML).

FREEPIK_API_KEY = "fpk_xxxxxxxxxxxxxxxxxxxxxxxx"

R2_ACCOUNT_ID        = "your-cloudflare-account-id"
R2_ACCESS_KEY_ID     = "your-r2-access-key-id"
R2_SECRET_ACCESS_KEY = "your-r2-secret-access-key"
R2_BUCKET            = "product-recolor-uploads"
